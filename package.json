{
  "name": "duola",
  "version": "0.1.0",
  "description": "Polymarket copy-trading CLI — track smart money, backtest, and auto-copy trades",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/duolaAmengweb3/duola.git"
  },
  "keywords": [
    "polymarket",
    "copy-trading",
    "prediction-market",
    "cli",
    "trading-bot"
  ],
  "bin": {
    "duola": "./dist/index.js"
  },
  "files": [
